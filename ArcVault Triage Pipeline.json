    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst prompt = `Write a 2-3 sentence human-readable summary of this support ticket for the receiving team.\\n\\nOriginal message: ${data.raw_message}\\nCategory: ${data.category}\\nPriority: ${data.priority}\\nCore issue: ${data.core_issue}\\nIdentifiers: ${data.extracted_identifiers}`;\n\nreturn [{\n  json: {\n    ...data,\n    gemini_body: JSON.stringify({\n      systemInstruction: { parts: [{ text: 'You are a support ticket summarizer. Write a clear, professional 2-3 sentence summary suitable for the internal team receiving this ticket. Be factual, include key identifiers, and state the required action. Return only the summary text, no JSON, no bullet points, no headings.' }] },\n      contents: [{ role: 'user', parts: [{ text: prompt }] }],\n      generationConfig: { temperature: 0.2 }\n    })\n  }\n}];"
      },
      "id": "4013b22c-25aa-40d3-b0d6-29facec07a12",
      "name": "Build Summary Request",
      "type": "n8n-nodes-base.code",
