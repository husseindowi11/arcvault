      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nreturn [{\n  json: {\n    raw_message: body.message || '',\n    source: body.source || 'Unknown',\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
