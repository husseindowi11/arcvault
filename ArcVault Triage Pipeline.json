      },
      "id": "0b2f48ee-f58c-4994-a4e3-79845b9ab3d1",
      "name": "Call Gemini - Summarize",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -256,
        192
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9hjD9JR6GSd22wRh",
          "name": "Header Auth account"
        }
