    {
      "parameters": {
        "jsCode": "const responseData = $input.first().json;\nconst prevData = $('Build Classification Request').first().json;\nconst raw = responseData.candidates[0].content.parts[0].text;\nconst parsed = JSON.parse(raw);\nreturn [{\n  json: {\n    raw_message: prevData.raw_message,\n    source: prevData.source,\n    timestamp: prevData.timestamp,\n    category: parsed.category,\n    priority: parsed.priority,\n    confidence_score: parsed.confidence_score\n  }\n}];"
      },
      "id": "2d192a80-81e5-465b-a646-af7192b3cfa2",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1456,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst prompt = `Extract structured information from this customer message.\\n\\nMessage: ${data.raw_message}\\nCategory: ${data.category}\\n\\nReturn a JSON object with this exact structure:\\n{\\n  \\\"core_issue\\\": \\\"<one sentence describing the core problem or request>\\\",\\n  \\\"extracted_identifiers\\\": {\\n    \\\"account_id\\\": \\\"<account ID or username if mentioned, else null>\\\",\\n    \\\"invoice_number\\\": \\\"<invoice number if mentioned, else null>\\\",\\n    \\\"error_code\\\": \\\"<error code if mentioned, else null>\\\",\\n    \\\"other\\\": \\\"<any other relevant ID or reference, else null>\\\"\\n  },\\n  \\\"urgency_signal\\\": \\\"<one of: Critical, Elevated, Normal>\\\"\\n}\\n\\nUrgency signal:\\n- Critical: multiple users affected, full service outage, data loss, security breach\\n- Elevated: single user blocked, billing discrepancy, auth failure, time-sensitive\\n- Normal: general inquiry, feature request, non-blocking question`;\n\nreturn [{\n  json: {\n    ...data,\n    gemini_body: JSON.stringify({\n      systemInstruction: { parts: [{ text: 'You are a support ticket enrichment agent. Extract structured information from customer messages.' }] },\n      contents: [{ role: 'user', parts: [{ text: prompt }] }],\n      generationConfig: { temperature: 0, responseMimeType: 'application/json' }\n    })\n  }\n}];"
      },
      "id": "599fa82e-ee0e-4ebc-8d6c-e4b90c1d3820",
      "name": "Build Enrichment Request",
