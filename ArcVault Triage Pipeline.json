    {
      "parameters": {
        "jsCode": "const responseData = $input.first().json;\nconst prevData = $('Build Summary Request').first().json;\nconst summary = responseData.candidates[0].content.parts[0].text.trim();\n\nconst routingMap = {\n  'Bug Report': 'Engineering',\n  'Incident/Outage': 'Engineering',\n  'Feature Request': 'Product',\n  'Technical Question': 'IT/Security',\n  'Billing Issue': 'Billing'\n};\n\nconst msg = prevData.raw_message.toLowerCase();\nconst amountMatch = msg.match(/\\$[\\d,]+/);\nconst amount = amountMatch ? parseFloat(amountMatch[0].replace(/[$,]/g, '')) : 0;\n\nconst escalate =\n  prevData.confidence_score < 70 ||\n  msg.includes('outage') ||\n  msg.includes('down for all') ||\n  msg.includes('billing error') ||\n  amount > 500 ||\n  prevData.urgency_signal === 'Critical';\n\nreturn [{\n  json: {\n    timestamp: prevData.timestamp,\n    source: prevData.source,\n    raw_message: prevData.raw_message,\n    category: prevData.category,\n    priority: prevData.priority,\n    confidence_score: prevData.confidence_score,\n    core_issue: prevData.core_issue,\n    extracted_identifiers: prevData.extracted_identifiers,\n    urgency_signal: prevData.urgency_signal,\n    routing_destination: routingMap[prevData.category] || 'General',\n    escalation_flag: escalate,\n    summary: summary\n  }\n}];"
      },
