    {
      "parameters": {
        "jsCode": "const responseData = $input.first().json;\nconst prevData = $('Build Enrichment Request').first().json;\nconst raw = responseData.candidates[0].content.parts[0].text;\nconst parsed = JSON.parse(raw);\nreturn [{\n  json: {\n    raw_message: prevData.raw_message,\n    source: prevData.source,\n    timestamp: prevData.timestamp,\n    category: prevData.category,\n    priority: prevData.priority,\n    confidence_score: prevData.confidence_score,\n    core_issue: parsed.core_issue,\n    extracted_identifiers: JSON.stringify(parsed.extracted_identifiers),\n    urgency_signal: parsed.urgency_signal\n  }\n}];"
      },
      "id": "45359ba3-8494-4375-9bfa-60b6cc7905b5",
